# General
NODE_ENV=development
APP_NAME=Huelegood
APP_RELEASE_SHA=dev-local
APP_BASE_DIR=/var/www/huelegood/current
BACKUP_DIR=/var/backups/huelegood
BACKUP_RETENTION_DAYS=14

# Web
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Admin
ADMIN_PORT=3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# API
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/huelegood
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me
SESSION_SECRET=replace-me

# Openpay
OPENPAY_MERCHANT_ID=replace-me
OPENPAY_PRIVATE_KEY=replace-me
OPENPAY_PUBLIC_KEY=replace-me
OPENPAY_WEBHOOK_SECRET=replace-me
OPENPAY_SANDBOX=true

# Uploads
UPLOADS_PUBLIC_DIR=./storage/public
UPLOADS_PRIVATE_DIR=./storage/private

# Mail
MAIL_FROM=hello@huelegood.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Worker
WORKER_CONCURRENCY=5

# Smoke checks
WEB_HEALTH_URL=http://localhost:3000/health
ADMIN_HEALTH_URL=http://localhost:3001/health
API_HEALTH_URL=http://localhost:4000/api/v1/health/liveness
API_READINESS_URL=http://localhost:4000/api/v1/health/readiness
API_OPERATIONAL_URL=http://localhost:4000/api/v1/health/operational
