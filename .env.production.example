# General
NODE_ENV=production
APP_NAME=Huelegood
APP_RELEASE_SHA=release-20260319
APP_BASE_DIR=/var/www/huelegood/current
BACKUP_DIR=/var/backups/huelegood
BACKUP_RETENTION_DAYS=14

# Public URLs
NEXT_PUBLIC_APP_URL=https://huelegood.com
NEXT_PUBLIC_ADMIN_URL=https://admin.huelegood.com
NEXT_PUBLIC_API_URL=https://api.huelegood.com/api/v1
WEB_MAINTENANCE_MODE=false
WEB_MAINTENANCE_BYPASS_TOKEN=replace-me-optional

# Runtime ports
WEB_PORT=3000
ADMIN_PORT=3005
API_PORT=4000
WORKER_CONCURRENCY=5

# Infrastructure
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/huelegood
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace-me
SESSION_SECRET=replace-me

# Openpay
OPENPAY_MERCHANT_ID=replace-me
OPENPAY_PRIVATE_KEY=replace-me
OPENPAY_PUBLIC_KEY=replace-me
OPENPAY_WEBHOOK_SECRET=replace-me
OPENPAY_SANDBOX=false

# Uploads
UPLOADS_PUBLIC_DIR=/var/www/huelegood/shared/storage/public
UPLOADS_PRIVATE_DIR=/var/www/huelegood/shared/storage/private

# Cloudflare R2
R2_ACCOUNT_ID=replace-me
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_PUBLIC=assets
R2_BUCKET_PRIVATE=
R2_ENDPOINT=https://replace-me.r2.cloudflarestorage.com
R2_REGION=auto
R2_PUBLIC_BASE_URL=https://media.huelegood.com
NEXT_PUBLIC_STOREFRONT_MEDIA_BASE_URL=https://media.huelegood.com

# Bootstrap migration (one-shot)
# Use these values only while running scripts/migrate-bootstrap-users.sh.
BOOTSTRAP_ADMIN_NAME=Admin Huelegood
BOOTSTRAP_ADMIN_EMAIL=admin@huelegood.com
BOOTSTRAP_ADMIN_PASSWORD=replace-me
BOOTSTRAP_PAYMENTS_NAME=Operador de Pagos
BOOTSTRAP_PAYMENTS_EMAIL=pagos@huelegood.com
BOOTSTRAP_PAYMENTS_PASSWORD=replace-me
BOOTSTRAP_SELLER_NAME=Mónica Herrera
BOOTSTRAP_SELLER_EMAIL=monica@seller.com
BOOTSTRAP_SELLER_PASSWORD=replace-me
BOOTSTRAP_SELLER_VENDOR_CODE=VEND-014
BOOTSTRAP_CUSTOMER_NAME=Cliente Huelegood
BOOTSTRAP_CUSTOMER_EMAIL=cliente@huelegood.com
BOOTSTRAP_CUSTOMER_PASSWORD=replace-me

# Mail
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL="Huele Huele <no-reply@huelegood.com>"

# Smoke checks
WEB_HEALTH_URL=https://huelegood.com/health
ADMIN_HEALTH_URL=https://admin.huelegood.com/health
API_HEALTH_URL=https://api.huelegood.com/api/v1/health/liveness
API_READINESS_URL=https://api.huelegood.com/api/v1/health/readiness
API_OPERATIONAL_URL=https://api.huelegood.com/api/v1/health/operational
